#[test]
#[ignore]
fn test_awx_complexity_analysis() {
    let awx = get_awx_repo();
    let backend = build_awx_graph(&awx);

    use rbuilder_analysis::complexity::ComplexityAnalyzer;

    let analyzer = ComplexityAnalyzer::new(&backend);
    let report = analyzer.analyze().expect("Complexity analysis failed");

    println!("Complexity Report:");
    println!("  Average complexity: {:.2}", report.average);
    println!("  Max complexity: {}", report.max);
    println!("  High complexity functions: {}", report.high_complexity_count);

    assert!(report.max > 10, "Should have some complex functions");
}

#[test]
#[ignore]
fn test_awx_security_scan() {
    let awx = get_awx_repo();
    let backend = build_awx_graph(&awx);

    use rbuilder_security::scanner::SecurityAnalyzer;

    let analyzer = SecurityAnalyzer::new(&backend);
    let vulnerabilities = analyzer.scan().expect("Security scan failed");

    println!("Security Scan Results:");
    println!("  Total findings: {}", vulnerabilities.len());

    // Group by severity
    let critical = vulnerabilities.iter().filter(|v| v.severity == "critical").count();
    let high = vulnerabilities.iter().filter(|v| v.severity == "high").count();
    let medium = vulnerabilities.iter().filter(|v| v.severity == "medium").count();

    println!("  Critical: {}", critical);
    println!("  High: {}", high);
    println!("  Medium: {}", medium);
}

#[test]
#[ignore]
fn test_awx_call_graph_depth() {
    let awx = get_awx_repo();
    let backend = build_awx_graph(&awx);

    use rbuilder_analysis::callgraph::CallGraph;

    let callgraph = CallGraph::from_backend(&backend).expect("Failed to build call graph");

    println!("Call Graph Stats:");
    println!("  Total nodes: {}", callgraph.node_count());
    println!("  Total edges: {}", callgraph.edge_count());

    // Find deepest call chain
    let max_depth = callgraph.max_depth().unwrap_or(0);
    println!("  Max call depth: {}", max_depth);

    assert!(max_depth > 3, "Should have call chains deeper than 3");
}


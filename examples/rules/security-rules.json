{
  "name": "security",
  "version": "1.0",
  "description": "Security and quality labeling rules",
  "rules": [
    {
      "name": "critical_security_function",
      "description": "Label auth/security related functions",
      "match": {
        "type": "name_pattern",
        "pattern": "(?i)(auth|login|verify|token|password)"
      },
      "actions": [
        {"type": "add_label", "label": "security:critical"},
        {"type": "set_metadata", "key": "audit_required", "value": "true"}
      ]
    },
    {
      "name": "high_complexity",
      "description": "Label functions with high cyclomatic complexity",
      "match": {
        "and": [
          {"type": "node_type", "value": "Function"},
          {"type": "complexity_gt", "value": 15}
        ]
      },
      "actions": [
        {"type": "add_label", "label": "quality:high-complexity"},
        {"type": "set_complexity_override", "level": "HIGH"}
      ]
    },
    {
      "name": "deprecated_api",
      "description": "Label deprecated API usage patterns",
      "match": {
        "type": "name_pattern",
        "pattern": "(?i)(deprecated|legacy|old_)"
      },
      "actions": [
        {"type": "add_label", "label": "deprecated"}
      ]
    }
  ]
}
